units = int(input("Enter electricity units: "))

bill = 0

if units <= 50:
    bill = units * 0.50

elif units <= 200:
    bill = (50 * 0.50) + ((units - 50) * 0.75)

elif units <= 450:
    bill = (50 * 0.50) + (150 * 0.75) + ((units - 200) * 1.20)

else:
    bill = (50 * 0.50) + (150 * 0.75) + (250 * 1.20) + ((units - 450) * 1.50)

50

bill = bill + (0.20 * bill)

print("Total electricity bill = ₹",bill)