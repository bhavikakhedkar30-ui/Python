def even_factorial(n):
    fact = 1
    for i in range(1, n + 1):
        fact *= i
    return fact

def odd_factorial(n):
    fact = 1
    for i in range(1, n + 1):
        fact *= i
    return fact


num = int(input("Enter a number: "))

if num % 2 == 0:
    print("Even number")
    print("Factorial =", even_factorial(num))
else:
    print("Odd number")
    print("Factorial =", odd_factorial(num))
    
    
